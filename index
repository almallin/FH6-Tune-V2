<script>
const $=id=>document.getElementById(id);
const vn=id=>{const e=$(id);return e?parseFloat(e.value):NaN};
const valid=(a,b)=>!isNaN(a)&&!isNaN(b)&&b>a;
const clamp=(v,mn,mx)=>Math.min(Math.max(v,mn),mx);
const fromMin=(mn,mx,p)=>mn+(mx-mn)*p;

function setRes(id,val,dp,cls){
  const e=$(id);if(!e)return;
  if(val===null||isNaN(val)){e.textContent='—';e.className=(e.className.includes('single')?'res-single-val':'res-val')+' empty';return;}
  e.textContent=val.toFixed(dp);
  e.className=(e.className.includes('single')?'res-single-val':'res-val')+(cls?' '+cls:'');
}

function getWeightKg(){const w=vn('car-weight'),u=$('weight-unit').value;if(isNaN(w)||w<=0)return null;return u==='lbs'?w*0.453592:w}
function wFactor(){const kg=getWeightKg();return kg===null?0.5:clamp((kg-700)/1300,0,1)}
function getFW(){return vn('fw-slider')/100}

// PSI targets by compound — guide says rally 21-26, others higher
function tyrePSI(){
  const c=$('tyre-compound').value;
  const base={rally:23.5,semi:30,slick:30,street:26,sport:27,drift:30,drag:20}[c]||26;
  const wAdj=(wFactor()-0.5)*3; // heavier = more pressure
  return base+wAdj;
}

function showTab(id,btn){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  $('tab-'+id).classList.add('active');
  btn.classList.add('active');
  btn.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
}

function updateDiffTabs(){
  const dt=$('drivetrain').value;
  $('diff-none').classList.toggle('diff-hidden',dt!=='');
  $('diff-rwd').classList.toggle('diff-hidden',dt!=='rwd');
  $('diff-fwd').classList.toggle('diff-hidden',dt!=='fwd');
  $('diff-awd').classList.toggle('diff-hidden',dt!=='awd');
}

let gearFocus='race';
const GEAR_DATA={
  race:{note:'<b>Circuit:</b> As short as possible while avoiding hitting the rev limiter on straights. Stay in power band through corners.',bottom:'<b>Guide:</b> Tune gearing AFTER setting aero — they affect each other.'},
  sprint:{note:'<b>Sprint:</b> Longer gears for higher top speed on long straights. Accept slower corner acceleration.',bottom:'<b>Sprint:</b> Prioritise top speed over corner exit punch.'},
  drag:{note:'<b>0–60:</b> Shortest possible gears. Make first gear longer only if hitting limiter immediately off the line.',bottom:'<b>Drag:</b> First gear length is the main variable — too short = limiter, too long = slow.'}
};
function setGearFocus(f){
  gearFocus=f;
  document.querySelectorAll('.focus-btn').forEach(b=>b.classList.remove('active'));
  $('focus-'+f).classList.add('active');
  $('gear-focus-note').innerHTML=GEAR_DATA[f].note;
  $('gear-bottom-note').innerHTML=GEAR_DATA[f].bottom;
  calc();
}

function calc(){
  const fw=getFW(),rw=1-fw;
  $('fw-val').textContent=Math.round(fw*100)+'%';
  $('rw-val').textContent=Math.round(rw*100)+'%';
  const dt=$('drivetrain').value,wf=wFactor();

  // ── TYRES — fixed 15-55, front/rear differ by axle weight
  const psi=tyrePSI();
  // heavier axle = slightly lower pressure (more contact patch needed)
  setRes('tp-f-res',clamp(psi+(fw-0.5)*(-1.5),15,55),1);
  setRes('tp-r-res',clamp(psi+(rw-0.5)*(-1.5),15,55),1);

  // ── GEARING — map focus position into provided range
  const focusPos={race:0.65,sprint:0.45,drag:0.80}[gearFocus]||0.65;
  const fdMn=vn('fd-min'),fdMx=vn('fd-max');
  if(valid(fdMn,fdMx)){
    setRes('fd-res',fromMin(fdMn,fdMx,focusPos),2);
    $('fd-sub').textContent={race:'65% toward accel (circuit)',sprint:'45% toward speed',drag:'80% toward accel (drag)'}[gearFocus];
  } else {
    $('fd-res').textContent='—';$('fd-res').className='res-single-val empty';
    $('fd-sub').textContent='Enter min/max above';
  }

  // ── ALIGNMENT — fixed ranges, guide-specific values
  // Camber: guide says -0.5 to -1.0 front, -0.3 to -0.5 rear
  // Scale slightly within those ranges based on weight/drivetrain
  let camF,camR;
  if(dt==='rwd'){camF=-0.8;camR=-0.4;}
  else if(dt==='fwd'){camF=-0.6;camR=-0.7;}
  else{camF=-0.7;camR=-0.4;} // AWD: guide says -0.5/-0.3 as example
  // nudge slightly more negative for heavier cars
  camF=clamp(camF-(wf-0.5)*0.3,-1.0,0.0);
  camR=clamp(camR-(wf-0.5)*0.2,-0.8,0.0);
  setRes('ca-f-res',camF,1);
  setRes('ca-r-res',camR,1);
  // Toe: near zero, slight rear toe-in for RWD
  setRes('toe-f-res',0.0,1);
  setRes('toe-r-res',dt==='rwd'?-0.1:0.0,1);
  // Caster: 7.0
  setRes('cast-res',7.0,1);

  // ── ARBs — fixed 1-65
  // Guide: AWD starts at 1F/65R. RWD front < rear.
  // Front: lower for AWD (to reduce understeer), scale with weight
  let arbF,arbR;
  if(dt==='awd'){
    // Guide says 1/65 as starting point for AWD
    arbF=clamp(1+(fw-0.5)*20+(wf-0.5)*10,1,40);
    arbR=65; // start max rear for AWD
  } else if(dt==='rwd'){
    arbF=clamp(20+(fw-0.5)*15+(wf-0.5)*12,10,50);
    arbR=clamp(55+(rw-0.5)*10+(wf-0.5)*8,35,65);
  } else {
    arbF=clamp(40+(fw-0.5)*15+(wf-0.5)*10,25,65);
    arbR=clamp(30+(rw-0.5)*10+(wf-0.5)*8,15,55);
  }
  setRes('arb-f-res',arbF,1);
  setRes('arb-r-res',arbR,1);

  // ── SPRINGS — single min/max, unique front/rear
  // Guide: align with weight dist, soft overall. Rear heavier = higher rear springs.
  const spMn=vn('sp-min'),spMx=vn('sp-max');
  // base ~30% of range (soft), heavier axle gets higher value
  const spFPos=clamp(0.30+(fw-0.5)*0.35+(wf-0.5)*0.15,0.15,0.60);
  const spRPos=clamp(0.30+(rw-0.5)*0.35+(wf-0.5)*0.15,0.15,0.60);
  setRes('sp-f-res',valid(spMn,spMx)?fromMin(spMn,spMx,spFPos):null,1);
  setRes('sp-r-res',valid(spMn,spMx)?fromMin(spMn,spMx,spRPos):null,1);

  // ── RIDE HEIGHT — single min/max
  // Guide: max front for turn-in, lower rear for rotation/top speed
  const rhMn=vn('rh-min'),rhMx=vn('rh-max');
  setRes('rh-f-res',valid(rhMn,rhMx)?rhMx:null,1); // max front
  setRes('rh-r-res',valid(rhMn,rhMx)?fromMin(rhMn,rhMx,0.25):null,1); // low rear

  // ── DAMPING — fixed 1-20
  // Guide: rebound ~8-11 (middle), bump very low ~3-5
  // Higher rear bump for rotation
  const rbFTarget=clamp(8.5+(fw-0.5)*2+(wf-0.5)*2,7,13);
  const rbRTarget=clamp(9.5+(rw-0.5)*2+(wf-0.5)*2,8,14); // rear slightly higher
  setRes('rb-f-res',clamp(rbFTarget,1,20),1);
  setRes('rb-r-res',clamp(rbRTarget,1,20),1);
  // Bump: ~40% of rebound, rear slightly higher for rotation
  setRes('bm-f-res',clamp(rbFTarget*0.38,1,20),1);
  setRes('bm-r-res',clamp(rbRTarget*0.45,1,20),1); // rear bump slightly higher

  // ── AERO — single min/max
  // Guide: front always max, rear adjusted for stability (~low-mid)
  const aeMn=vn('ae-min'),aeMx=vn('ae-max');
  setRes('ae-f-res',valid(aeMn,aeMx)?aeMx:null,0); // max front
  setRes('ae-r-res',valid(aeMn,aeMx)?fromMin(aeMn,aeMx,0.35):null,0); // ~35% rear starting point

  // ── BRAKES — fixed 0-100 balance, 0-200 pressure
  // Guide: 48-49% (toward rear for rotation)
  setRes('br-bal-res',Math.round(clamp(48+(fw-0.5)*4,46,52)),0);
  setRes('br-pres-res',100,0);

  // ── DIFF — fixed 0-100
  if(dt==='rwd'){
    // Guide: accel as high as possible 80-100%, decel start 0
    setRes('df-r-acc-res',100,0);
    setRes('df-r-dec-res',0,0);
  } else if(dt==='fwd'){
    setRes('df-f-acc-res',100,0);
    setRes('df-f-dec-res',0,0);
  } else if(dt==='awd'){
    // Guide: 100% both front and rear accel, decel 0 (rear +5 if needed)
    setRes('df-af-acc-res',100,0);
    setRes('df-af-dec-res',0,0);
    setRes('df-ar-acc-res',100,0);
    setRes('df-ar-dec-res',0,0);
    // Centre: 80-84% rear
    const cMin=vn('df-ctr-min'),cMax=vn('df-ctr-max');
    // target 80% of the way through range toward rear bias
    setRes('df-ctr-res',valid(cMin,cMax)?clamp(fromMin(cMin,cMax,0.80),cMin,cMax):80,0);
  }
}

// ── GARAGE ─────────────────────────────────────────────────────────────────
const FIELDS=['car-name','car-class','drivetrain','car-power','car-weight','weight-unit','tyre-compound','fw-slider',
  'fd-min','fd-max','sp-min','sp-max','rh-min','rh-max','ae-min','ae-max','df-ctr-min','df-ctr-max'];
function readState(){const s={};FIELDS.forEach(id=>{const e=$(id);if(e)s[id]=e.value});return s}
function applyState(s){FIELDS.forEach(id=>{const e=$(id);if(e&&s[id]!==undefined)e.value=s[id]});updateDiffTabs();setGearFocus(gearFocus);calc()}
function loadGarage(){try{return JSON.parse(localStorage.getItem('fh6_garage_g4')||'[]')}catch{return[]}}
function saveGarage(g){localStorage.setItem('fh6_garage_g4',JSON.stringify(g))}
function renderGarage(){
  const g=loadGarage(),list=$('garage-list');
  if(!g.length){list.innerHTML='<span style="font-size:11px;color:var(--muted)">No saved cars yet.</span>';return}
  list.innerHTML='';
  g.forEach((car,i)=>{
    const d=document.createElement('div');d.className='gc';
    d.innerHTML=`<div><div class="gc-name">${car.label}</div><div class="gc-meta">${car.state['car-class']||''} · ${(car.state['drivetrain']||'').toUpperCase()}</div></div><button class="gc-del" onclick="delCar(${i});event.stopPropagation()">×</button>`;
    d.onclick=()=>{applyState(car.state);toggleGarage()};
    list.appendChild(d);
  });
}
function delCar(i){const g=loadGarage();g.splice(i,1);saveGarage(g);renderGarage()}
function toggleGarage(){const p=$('garage-panel');p.classList.toggle('open');if(p.classList.contains('open'))renderGarage()}
function openSave(){$('save-name').value=$('car-name').value||'My Car';$('save-modal').classList.add('open');$('save-name').focus()}
function closeModal(){$('save-modal').classList.remove('open')}
function confirmSave(){
  const label=$('save-name').value.trim()||'Unnamed';
  const g=loadGarage();g.push({label,state:readState()});saveGarage(g);closeModal();renderGarage();
}

// ── LIVE STATS ──────────────────────────────────────────────────────────────
let liveOpen=false;
function toggleLive(){liveOpen=!liveOpen;$('live-body').classList.toggle('open',liveOpen);$('live-toggle').textContent=liveOpen?'▲ collapse':'▼ expand'}
function setInd(id,cls,txt){const e=$(id);if(e){e.className='live-ind '+cls;e.textContent=txt}}
function setDelta(id,b,a,lower){
  const e=$(id);if(!e)return;
  if(isNaN(b)||isNaN(a)){e.textContent='—';e.className='perf-d same';return}
  const diff=a-b,ok=lower?diff<0:diff>0;
  e.textContent=(diff>0?'+':'')+diff.toFixed(Math.abs(diff)<1?3:1);
  e.className='perf-d '+(ok?'better':diff===0?'same':'worse');
}
function updateLive(){
  const m=parseFloat($('lv-mech').value);
  if(!isNaN(m)){if(m>=0.55&&m<=0.65)setInd('lv-mech-ind','good','✓');else if(m<0.55)setInd('lv-mech-ind','low','Low');else setInd('lv-mech-ind','high','High');}
  else setInd('lv-mech-ind','neutral','—');
  const ab=parseFloat($('lv-aero-bal').value);
  if(!isNaN(ab)){if(ab>=0.40&&ab<=0.45)setInd('lv-aero-bal-ind','good','✓');else if(ab<0.40)setInd('lv-aero-bal-ind','low','Low');else setInd('lv-aero-bal-ind','high','High');}
  else setInd('lv-aero-bal-ind','neutral','—');
  const ae=parseFloat($('lv-aero-eff').value);
  if(!isNaN(ae)){if(ae>=0.85)setInd('lv-aero-eff-ind','good','Good');else if(ae>=0.70)setInd('lv-aero-eff-ind','low','Mod');else setInd('lv-aero-eff-ind','high','Drag');}
  else setInd('lv-aero-eff-ind','neutral','—');
  setDelta('pd-bk60',parseFloat($('pf-bk60-b').value),parseFloat($('pf-bk60-a').value),true);
  setDelta('pd-ac60',parseFloat($('pf-ac60-b').value),parseFloat($('pf-ac60-a').value),true);
  setDelta('pd-spd',parseFloat($('pf-spd-b').value),parseFloat($('pf-spd-a').value),false);
  setDelta('pd-lg',parseFloat($('pf-lg-b').value),parseFloat($('pf-lg-a').value),false);
}

// ── PWA ─────────────────────────────────────────────────────────────────────
const manifest={name:'FH6 Tune G4',short_name:'FH6 G4',display:'standalone',background_color:'#0a0f1a',theme_color:'#2d8cff',start_url:'.',icons:[{src:"data:image/svg+xml,"+encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512"><rect width="512" height="512" rx="80" fill="#0a0f1a"/><text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-family="Arial Black" font-size="180" font-weight="900" fill="#2d8cff">G4</text><text x="50%" y="78%" dominant-baseline="middle" text-anchor="middle" font-family="Arial" font-size="72" fill="#4a6080">TUNE</text></svg>'),sizes:'512x512',type:'image/svg+xml',purpose:'any maskable'}]};
const mBlob=new Blob([JSON.stringify(manifest)],{type:'application/json'});
$('pwa-manifest').href=URL.createObjectURL(mBlob);
if('serviceWorker' in navigator){
  const sw=`self.addEventListener('install',e=>{self.skipWaiting()});self.addEventListener('fetch',e=>{e.respondWith(fetch(e.request).catch(()=>caches.match(e.request)))});`;
  navigator.serviceWorker.register(URL.createObjectURL(new Blob([sw],{type:'text/javascript'}))).catch(()=>{});
}

